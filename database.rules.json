{
  "rules": {
    "tinaco": {
      "lectura": {
        ".read": "auth != null",
        ".write": "auth != null && newData.hasChildren(['d', 'n', 'p', 'a', 't', 's'])",
        "p": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
        }
      }
    }
  }
}